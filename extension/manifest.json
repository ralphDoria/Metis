{
  "manifest_version": 3,
  "name": "Metis — A Cognitive Sanctuary",
  "short_name": "Metis",
  "version": "0.1.0",
  "description": "Awareness layer for Instagram Reels. Predicts neural response to feed content and surfaces session-level feedback.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "Metis",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "background": {
    "service_worker": "src/background.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.instagram.com/*"
      ],
      "js": ["src/content/index.tsx"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "permissions": [
    "storage",
    "scripting",
    "offscreen",
    "tabs",
    "tabCapture",
    "activeTab"
  ],
  "host_permissions": [
    "https://*.instagram.com/*",
    "https://metis.mnkjoshi.ca/*",
    "http://localhost:8000/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*", "src/offscreen/offscreen.html"],
      "matches": ["https://*.instagram.com/*"]
    }
  ]
}
